name: wiki-dispatch

# Trigger wiki-portal rebuild when docs/ changes.
# Spec: cloud/wiki-web docs/superpowers/specs/2026-05-22-wiki-portal-multitenant.md §5.1
#
# Security: github.repository / github.sha / github.ref are non-user-controlled
# context values (set by GitHub Actions infra, not by external input). They are
# inlined into JSON client-payload (parsed by GitHub Actions, not shell).
# No `run:` steps consume untrusted input here.

on:
  push:
    branches: [main, master, develop]
    paths:
      - 'docs/**'

jobs:
  trigger-wiki-rebuild:
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: Build dispatch payload
        id: payload
        env:
          SOURCE_REPO: ${{ github.repository }}
          COMMIT_SHA: ${{ github.sha }}
          REF_NAME: ${{ github.ref }}
        run: |
          jq -n \
            --arg source_repo "$SOURCE_REPO" \
            --arg commit "$COMMIT_SHA" \
            --arg ref "$REF_NAME" \
            '{source_repo: $source_repo, commit: $commit, ref: $ref}' \
            > payload.json
          echo "payload_path=payload.json" >> "$GITHUB_OUTPUT"

      - name: Trigger wiki-portal rebuild
        env:
          DISPATCH_TOKEN: ${{ secrets.WIKI_PORTAL_DISPATCH_TOKEN }}
        run: |
          curl -sSf \
            -X POST \
            -H "Accept: application/vnd.github+json" \
            -H "Authorization: Bearer $DISPATCH_TOKEN" \
            -H "X-GitHub-Api-Version: 2022-11-28" \
            https://api.github.com/repos/qiurui144/wiki-portal/dispatches \
            -d "$(jq -n --arg event 'wiki-content-update' --slurpfile payload payload.json '{event_type: $event, client_payload: $payload[0]}')"

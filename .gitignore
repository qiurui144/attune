*.py[cod]
*$py.class
*.egg-info/
dist/
.pytest_cache/
.ruff_cache/
# 例外：Attune UI 的 dist 是 Rust include_str! 依赖，必须入仓
!rust/crates/attune-server/ui/dist/
build/
*.egg
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project
*.db
*.db-journal

# Dev screenshots（根目录临时截图；已归档的走 docs/screenshots/ 由仓库管理）
/*.png

# Playwright MCP runtime
.playwright-mcp/
chroma_data/
# 锚定到仓库根 — 仅忽略 /models 顶层目录 (ML 模型缓存), 不影响
# python/src/attune_python/models/ 等 Python 包目录. 历史 bug: 无锚的
# models/ 让 CI 装出的 wheel 缺 schemas 子包导致 ImportError
# ML 模型 + 二进制权重 — 同样需要全 glob (避免锚定不一致, R19 adv reviewer 提)
/models/
ai-models/
*.onnx
# *.bin / *.xml: 锚到 ML 数据目录, 避免误伤源码里的 .bin/.xml (如 Tauri icons,
# 配置示例). 实际 ML 权重均在 models/ai-models/ 下, 这两条 glob 也已被这两个
# 目录的 ignore 规则覆盖, 留作显式保险.
models/**/*.bin
models/**/*.xml
ai-models/**/*.bin
ai-models/**/*.xml

# Node
node_modules/
extension/dist/

# Packaging
*.AppImage
*.exe
*.spec.bak

# Logs
*.log
logs/

# Config (local overrides)
config.local.yaml

# Environment
.env
.env.local
.worktrees/
.playwright-mcp/

# Tauri signing keys（私钥永不入 git；公钥已嵌进 tauri.conf.json）
apps/attune-desktop/keys/dev_signing.key
apps/attune-desktop/keys/dev_signing.key.pub

# 测试报告 (运行时生成)
tests/reports/

# 临时调试目录 (CLAUDE.md 约定)
tmp/

# Claude Code 工具产物
.claude/

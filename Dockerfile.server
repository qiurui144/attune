# Dockerfile.server — attune headless server (server + embedded Web UI)
# Binary: attune-server-headless (attune-server crate)
# Port: 18900
# Usage: docker build -f Dockerfile.server -t attune-server:local .

# ── Stage 1: UI build ─────────────────────────────────────────────────────────
FROM node:20-alpine AS ui-builder

WORKDIR /ui
COPY rust/crates/attune-server/ui/package*.json ./
RUN npm ci

COPY rust/crates/attune-server/ui/ ./
RUN npm run build

# ── Stage 2: Rust builder ─────────────────────────────────────────────────────
# ubuntu:24.04 (glibc 2.39) matches ORT prebuilt binaries (glibc 2.38+)
FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    build-essential curl pkg-config libssl-dev cmake ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install Rust 1.91 (minimum: kreuzberg-paddle-ocr requires 1.91)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain 1.91 --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /src

COPY rust/Cargo.toml rust/Cargo.lock ./rust/
COPY rust/crates ./rust/crates

# Inject pre-built UI dist (server embeds via include_str!)
COPY --from=ui-builder /ui/dist ./rust/crates/attune-server/ui/dist/

WORKDIR /src/rust
RUN cargo build --release -p attune-server

# Collect all needed files into /dist (binary + any ORT .so from copy-dylibs)
RUN mkdir -p /dist/lib && \
    cp target/release/attune-server-headless /dist/ && \
    find target/release -maxdepth 1 -name 'libonnxruntime*.so*' -exec cp {} /dist/lib/ \; ; \
    true

# ── Stage 3: runtime ──────────────────────────────────────────────────────────
FROM ubuntu:24.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    ca-certificates libssl3 && \
    rm -rf /var/lib/apt/lists/*

# Non-root user
RUN useradd -r -s /bin/false -d /data attune && \
    mkdir -p /data && chown attune:attune /data

COPY --from=builder /dist/attune-server-headless /usr/local/bin/attune-server-headless
COPY --from=builder /dist/lib/ /usr/local/lib/

USER attune
WORKDIR /data

EXPOSE 18900
ENTRYPOINT ["attune-server-headless"]
CMD ["--bind", "0.0.0.0:18900"]

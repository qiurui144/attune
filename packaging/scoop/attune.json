{
  "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
  "version": "1.0.0",
  "description": "Private AI Knowledge Companion — local-first hybrid intelligence (CLI + server).",
  "homepage": "https://engi-stack.com",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/qiurui144/attune/releases/download/v1.0.0/attune-windows-x86_64.tar.gz",
      "hash": "REPLACE_WITH_ACTUAL_SHA256_FROM_RELEASE_ASSET",
      "extract_dir": ""
    }
  },
  "bin": [
    "attune.exe",
    "attune-server-headless.exe"
  ],
  "checkver": {
    "github": "https://github.com/qiurui144/attune",
    "regex": "tag/v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/qiurui144/attune/releases/download/v$version/attune-windows-x86_64.tar.gz"
      }
    },
    "hash": {
      "url": "$url.sha256"
    }
  },
  "notes": [
    "Attune CLI + headless server installed.",
    "Quick start:",
    "  attune --help                  # CLI usage",
    "  attune-server-headless         # start server on :18900",
    "",
    "Desktop GUI (Tauri) is distributed via GitHub Releases as NSIS installer:",
    "  https://github.com/qiurui144/attune/releases/latest",
    "",
    "Or install via winget: winget install qiurui144.Attune"
  ]
}
